# Supabase
SUPABASE_URL=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
VITE_ENABLE_DEMO_MODE=false
VITE_ENABLE_FOUNDER_WORKSPACE=false

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PERSONAL_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...

# Groq
GROQ_API_KEY=gsk_...

# Claude (primary AI provider)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI
OPENAI_API_KEY=sk-proj-...

# Optional Daily Capture AI Assist
# Public frontend endpoint. This is safe to expose.
VITE_CAPTURE_AI_ENDPOINT=/api/capture-ai-classify

# Server-only Capture AI secrets. Do not prefix these with VITE_.
CAPTURE_AI_PROVIDER=
CAPTURE_AI_ENDPOINT=
CAPTURE_AI_API_KEY=
CAPTURE_AI_MODEL=

# App
VITE_APP_URL=http://localhost:5173
